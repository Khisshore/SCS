{
  "name": "scs",
  "productName": "SCS",
  "version": "1.0.0",
  "description": "Professional offline-first Student Collection System for educational institutions",
  "author": "SCS Team",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"cross-env NODE_ENV=development vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:dir": "vite build && electron-builder --dir",
    "clean": "rimraf dist dist-electron node_modules/.vite"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.19",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@vitejs/plugin-react": "^5.1.3",
    "chart.js": "^4.5.1",
    "electron-updater": "^6.3.9",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "ogl": "^1.0.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.182.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.scs.app",
    "publish": [
      {
        "provider": "github",
        "owner": "khiss-inti",
        "repo": "scs-system"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    }
  }
}
