{
  "name": "neotrackr",
  "productName": "NeoTrackr",
  "version": "1.0.0",
  "description": "Professional offline-first payment management system for educational institutions",
  "author": "NeoTrackr Team",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"cross-env NODE_ENV=development vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:dir": "vite build && electron-builder --dir",
    "clean": "rimraf dist dist-electron node_modules/.vite"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "rimraf": "^6.1.2",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "xlsx": "^0.18.5",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.neotrackr.app",
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "YOUR_REPO_NAME"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
